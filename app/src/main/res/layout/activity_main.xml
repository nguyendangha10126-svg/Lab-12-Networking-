<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Phần nền xanh phía trên (Gradient Look) -->
    <View
        android:id="@+id/header_view"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="#1E88E5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="35dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAB 12 NETWORKING"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xử lý Networking &amp; JSON"
            android:textColor="#E3F2FD"
            android:layout_marginTop="6dp"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Thẻ Card trắng chứa nội dung kết quả -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_view"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="-70dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIÊU ĐỀ BÀI VIẾT ĐẦU TIÊN"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:layout_marginTop="10dp"
                android:background="#1E88E5" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:minHeight="140dp">

                <ProgressBar
                    android:id="@+id/loading_spinner"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#1E88E5"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_display_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vui lòng nhấn nút phía dưới để tải dữ liệu bài viết..."
                    android:textColor="#263238"
                    android:textSize="20sp"
                    android:lineSpacingExtra="8dp"
                    android:textStyle="italic" />
            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Nút bấm Việt hóa mượt mà -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_get_data"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:text="LẤY DỮ LIỆU TỪ API"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        android:backgroundTint="#1E88E5"
        app:icon="@android:drawable/stat_notify_sync"
        app:iconGravity="textStart"
        android:elevation="6dp"/>

</RelativeLayout>